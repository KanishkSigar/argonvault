# =====================================================================
# Object storage (S3-compatible — AWS S3, MinIO, etc.)
# =====================================================================

# Defaults match local MinIO (see project README).
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_BUCKET=vault
PRESIGN_EXPIRES_SECONDS=900

# =====================================================================
# Database
# =====================================================================
# SQLAlchemy URL. SQLite for portfolio scale; swap to Postgres in prod.
DATABASE_URL=sqlite:///./vault.db

# =====================================================================
# App secrets — generate with scripts/gen_secrets.py
# =====================================================================
JWT_SECRET=
JWT_EXPIRES_MINUTES=720

# Used to mint stable dummy salts for /auth/prelogin so attackers can't
# tell registered emails from unknown ones.
EMAIL_ENUM_PEPPER=

# =====================================================================
# Misc
# =====================================================================
CORS_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
